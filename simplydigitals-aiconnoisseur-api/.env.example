# ─────────────────────────────────────────────────────────────────────────────
# .env.example — copy to .env and fill in values
# NEVER commit .env to version control
# ─────────────────────────────────────────────────────────────────────────────

# Application
APP_NAME="ML Analytics API"
ENVIRONMENT=development         # development | testing | production
DEBUG=false
LOG_LEVEL=INFO

# Security — MUST be at least 32 random characters
SECRET_KEY=CHANGE_ME_to_a_long_random_string_of_at_least_32_chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database (PostgreSQL for production, SQLite for local dev)
DATABASE_URL=sqlite+aiosqlite:///./mlapi_dev.db
# DATABASE_URL=postgresql+asyncpg://mlapi:password@localhost:5432/mlapi
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_ECHO=false

# Rate limiting
RATE_LIMIT_PER_MINUTE=60

# ML artefacts storage
MODEL_ARTEFACT_DIR=./artefacts/models
MAX_DATASET_ROWS=500000

# AWS (required for cloud deployment only)
AWS_REGION=ap-southeast-1
S3_BUCKET_NAME=
